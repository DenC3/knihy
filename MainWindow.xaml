<Window x:Class="DatabázeKnih.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DatabázeKnih"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <!-- pevná šířka levého panelu, pravý zabere zbytek -->
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- formulář vlevo, v samostatném sloupci (bez velkého pravého marginu) -->
        <StackPanel Grid.Column="0" Margin="10,15,10,0" VerticalAlignment="Top" Height="409">
            <TextBlock TextWrapping="Wrap" Width="179" Margin="0,0,0,20"><Run Language="cs-cz" Text="Informace o produktu"/></TextBlock>
            <TextBlock TextWrapping="Wrap" Text="Název knihy:" Margin="0,0,0,2"/>
            <TextBox TextWrapping="Wrap" Text="" Margin="0,0,0,10"/>
            <TextBlock TextWrapping="Wrap" Text="Jméno autora:" Margin="0,0,0,2"/>
            <TextBox TextWrapping="Wrap" Text="" Margin="0,0,0,10"/>
            <TextBlock TextWrapping="Wrap" Text="Rok vydání:" Margin="0,0,0,2"/>
            <TextBox TextWrapping="Wrap" Text="" Margin="0,0,0,10"/>
            <TextBlock TextWrapping="Wrap" Text="Žánr:" Margin="0,0,0,2"/>
            <TextBox TextWrapping="Wrap" Text="" Margin="0,0,0,10"/>
            <TextBlock TextWrapping="Wrap" Text="Kusů skladem:" Margin="0,0,0,2"/>
            <TextBox TextWrapping="Wrap" Text="" Margin="0,0,0,10" TextChanged="TextBox_TextChanged_1"/>
            <CheckBox Content="Je dostupná"/>
            <Button Content="Přidat knihu" Margin="0,9,0,5"/>
            <Button Content="Smazat knihu" Margin="0,0,0,5"/>
            <Button Content="Upravit knihu" Margin="0,0,0,5"/>
            <Button Content="Vymazat formulář" Margin="0,0,0,5"/>
            <Button Content="Načíst knihu do formuláře" Margin="0,0,0,5"/>
        </StackPanel>

        <!-- DataGrid zabírá pravý sloupec -->
        <DataGrid Grid.Column="1" d:ItemsSource="{d:SampleData ItemCount=2}" Margin="10" SelectionChanged="DataGrid_SelectionChanged"/>
    </Grid>
</Window>
